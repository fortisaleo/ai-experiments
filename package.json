{
  "name": "ai-experiments",
  "version": "1.0.0",
  "description": "Open-source AI media experiments with fal.ai and Seedance.",
  "main": "dist/generate.js",
  "scripts": {
    "generate": "tsx src/generate.ts",
    "generate:candidates": "tsx src/generate.ts candidates",
    "generate:upscale": "tsx src/generate.ts upscale",
    "generate:image": "tsx src/generate.ts image",
    "generate:videos": "tsx src/generate.ts videos",
    "generate:001:candidates": "tsx src/generate.ts candidates --config experiments/001-seedance-facs/config.json",
    "generate:001:upscale": "tsx src/generate.ts upscale --config experiments/001-seedance-facs/config.json",
    "generate:001:storyboard": "tsx src/generate.ts --config experiments/001-seedance-facs/storyboard-config.json",
    "generate:001:multi-au": "tsx src/generate.ts --config experiments/001-seedance-facs/multi-au-sequence-config.json",
    "generate:001": "tsx src/generate.ts --config experiments/001-seedance-facs/config.json",
    "generate:002": "tsx src/generate.ts --config experiments/002-seedance-ugc-prompting/config.json",
    "generate:003": "tsx src/generate.ts --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "generate:003:music": "tsx src/generate.ts music --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "generate:003:candidates": "tsx src/generate.ts candidates --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "generate:003:image-pack": "tsx src/generate.ts image-pack --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "generate:003:video": "tsx src/generate.ts video --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "generate:003:assemble": "tsx src/generate.ts assemble --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "generate:003:members": "tsx src/generate.ts members --config experiments/003-kpop-idol-beauty-ugc/config.json",
    "audit": "tsx src/audit.ts",
    "audit:idea": "tsx src/audit.ts --agent content/seedance-prompt-lab/agents/idea-audit.md",
    "audit:character": "tsx src/audit.ts --model google/gemini-3.1-flash-lite --agent content/seedance-prompt-lab/agents/character-sheet-audit.md",
    "audit:keyframes": "tsx src/audit.ts --model google/gemini-3.1-flash-lite --agent content/seedance-prompt-lab/agents/keyframe-audit.md",
    "audit:storyboard": "tsx src/audit.ts --model google/gemini-3.1-flash-lite --agent content/seedance-prompt-lab/agents/storyboard-shot-audit.md",
    "audit:viral": "tsx src/audit.ts --agent content/seedance-prompt-lab/agents/viral-audit.md",
    "audit:video": "tsx src/audit.ts --agent content/seedance-prompt-lab/agents/video-critique.md",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git@github-fortisaleo:fortisaleo/ai-experiments.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
